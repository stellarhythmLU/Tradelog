// ═══════════════════════════════════════════════════════════════
// firestore.rules — Firestore 安全规则
//
// 部署方式：
//   1. 安装 Firebase CLI: npm install -g firebase-tools
//   2. firebase login
//   3. firebase init firestore（选择你的项目）
//   4. firebase deploy --only firestore:rules
//
// 或者直接在 Firebase Console 中粘贴以下规则：
//   Firebase Console → Firestore Database → 规则 → 粘贴 → 发布
// ═══════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 用户私人数据（只有本人可读写）────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── 市场行情数据（Python 脚本写入，登录用户可读）─────────────
    // 股票价格、K线、历史收盘价均为公开市场信息，不含个人隐私
    // 写入权限：仅 Firebase Admin SDK（Python 脚本）可写，前端不可写
    match /marketData/{document=**} {
      allow read:  if request.auth != null;
      allow write: if false;   // 仅 Admin SDK（服务账号）可写
    }

    // ── 拒绝所有其他路径 ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
